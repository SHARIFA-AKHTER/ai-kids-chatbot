generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
    //  url      = env("DATABASE_URL")
}

model UserProgress {
  id           String   @id 
  childName    String   @default("Little Friend")
  currentLevel String   @default("L1")
  currentMode  String   @default("Conversation")
  historyJson  String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
